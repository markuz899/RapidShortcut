{
  "manifest_version": 3,
  "name": "Stash",
  "description": "A quiet vault for the credentials you copy all day — search, reveal, copy.",
  "version": "2.0",
  "author": "Markuz",
  "action": {
    "default_popup": "popup.html",
    "default_icon": "icon.png",
    "default_title": "Stash"
  },
  "icons": {
    "128": "icon.png"
  },
  "permissions": ["storage"],
  "browser_specific_settings": {
    "gecko": {
      "id": "rapidshortcut@markuz",
      "strict_min_version": "109.0"
    }
  }
}
